# ===== SUPABASE (supabase.com -> your project -> Settings -> API) =====
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # keep secret, server only

# ===== GEMINI (aistudio.google.com -> Get API key) =====
GEMINI_API_KEY=your-gemini-key

# ===== GROQ fallback, optional (console.groq.com) =====
GROQ_API_KEY=

# ===== PAYSTACK (dashboard.paystack.com -> Settings -> API Keys) =====
PAYSTACK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx

# ===== PUSH NOTIFICATIONS (generated once, already created for you — see README) =====
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ===== APP =====
CRON_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=you@example.com          # your login email -> unlocks /admin
